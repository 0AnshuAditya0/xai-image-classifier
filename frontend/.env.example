# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production-please-use-openssl-rand-base64-32

# Backend API URL (optional - defaults to http://localhost:7860)
NEXT_PUBLIC_API_URL=http://localhost:7860

# Google OAuth (Optional - get from https://console.cloud.google.com)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
